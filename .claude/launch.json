{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend API (FastAPI)",
      "runtimeExecutable": "poetry",
      "runtimeArgs": ["run", "uvicorn", "app.backend.main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "Frontend (Vite + React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "app/frontend", "run", "dev"],
      "port": 5173
    }
  ]
}
